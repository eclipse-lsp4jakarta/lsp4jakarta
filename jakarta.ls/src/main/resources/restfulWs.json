    "Jakarta RESTful Web Services - RestClient class": {
      "prefix": "rest_client_class",
      "body": [
        "package ${1:packagename};",
        "",
        "import jakarta.ws.rs.client.Client;",
        "import jakarta.ws.rs.client.ClientBuilder;",
        "import jakarta.ws.rs.client.Entity;",
        "import jakarta.ws.rs.client.Invocation;",
        "import jakarta.ws.rs.client.WebTarget;",
        "import jakarta.ws.rs.core.MediaType;",
        "import jakarta.ws.rs.core.Response;",
        "import java.util.Map;",
        "",
        "public class ${TM_FILENAME_BASE} {",
        "",
        "\tprivate final Client client;",
        "",
        "\tpublic ${TM_FILENAME_BASE}() {",
        "\t\tthis.client = ClientBuilder.newClient();",
        "\t}",
        "",
        "\t/** Perform a GET request */",
        "\tpublic Response get(String url, Map<String, String> headers) {",
        "\t\tWebTarget target = client.target(url);",
        "\t\tInvocation.Builder builder = target.request(MediaType.APPLICATION_JSON);",
        "",
        "\t\tif (headers != null) {",
        "\t\t\theaders.forEach(builder::header);",
        "\t\t}",
        "",
        "\t\treturn builder.get();",
        "\t}",
        "",
        "\t/** Perform a POST request with JSON payload */",
        "\tpublic Response post(String url, String jsonPayload, Map<String, String> headers) {",
        "\t\tWebTarget target = client.target(url);",
        "\t\tInvocation.Builder builder = target.request(MediaType.APPLICATION_JSON);",
        "",
        "\t\tif (headers != null) {",
        "\t\t\theaders.forEach(builder::header);",
        "\t\t}",
        "",
        "\t\treturn builder.post(Entity.entity(jsonPayload, MediaType.APPLICATION_JSON));",
        "\t}",
        "",
        "\t/** Perform a PUT request with JSON payload */",
        "\tpublic Response put(String url, String jsonPayload, Map<String, String> headers) {",
        "\t\tWebTarget target = client.target(url);",
        "\t\tInvocation.Builder builder = target.request(MediaType.APPLICATION_JSON);",
        "",
        "\t\tif (headers != null) {",
        "\t\t\theaders.forEach(builder::header);",
        "\t\t}",
        "",
        "\t\treturn builder.put(Entity.entity(jsonPayload, MediaType.APPLICATION_JSON));",
        "\t}",
        "",
        "\t/** Perform a DELETE request */",
        "\tpublic Response delete(String url, Map<String, String> headers) {",
        "\t\tWebTarget target = client.target(url);",
        "\t\tInvocation.Builder builder = target.request(MediaType.APPLICATION_JSON);",
        "",
        "\t\tif (headers != null) {",
        "\t\t\theaders.forEach(builder::header);",
        "\t\t}",
        "",
        "\t\treturn builder.delete();",
        "\t}",
        "",
        "\t/** Close the underlying client */",
        "\tpublic void close() {",
        "\t\tclient.close();",
        "\t}",
        "}"
      ],
      "description": "Generic RestClient class with GET, POST, PUT, DELETE methods",
      "context": {
        "type": "jakarta.ws.rs.client.Client",
        "contentType": "class"
      }
    },
    "Jakarta RESTful Web Services - RestClient GET request": {
      "prefix": "rest_client_get",
      "body": [
        "Client client = ClientBuilder.newClient();",
        "try {",
        "\tWebTarget target = client.target(\"${1:http://example.com/api/resource}\");",
        "\tResponse response = target.request(MediaType.APPLICATION_JSON)",
        "\t\t\t.get();",
        "\t",
        "\tif (response.getStatus() == 200) {",
        "\t\t${2:String} result = response.readEntity(${2:String}.class);",
        "\t\t${3:// Process result}",
        "\t}",
        "\tresponse.close();",
        "} finally {",
        "\tclient.close();",
        "}"
      ],
      "description": "RestClient GET request with response handling",
      "context": {
        "type": "jakarta.ws.rs.client.Client",
        "contentType": "method"
      }
    },
    "Jakarta RESTful Web Services - RestClient POST request": {
      "prefix": "rest_client_post",
      "body": [
        "Client client = ClientBuilder.newClient();",
        "try {",
        "\tWebTarget target = client.target(\"${1:http://example.com/api/resource}\");",
        "\t${2:String} payload = ${3:\"{\\\"key\\\": \\\"value\\\"}\"};",
        "\t",
        "\tResponse response = target.request(MediaType.APPLICATION_JSON)",
        "\t\t\t.post(Entity.entity(payload, MediaType.APPLICATION_JSON));",
        "\t",
        "\tif (response.getStatus() == 201 || response.getStatus() == 200) {",
        "\t\t${4:String} result = response.readEntity(${4:String}.class);",
        "\t\t${5:// Process result}",
        "\t}",
        "\tresponse.close();",
        "} finally {",
        "\tclient.close();",
        "}"
      ],
      "description": "RestClient POST request with JSON payload",
      "context": {
        "type": "jakarta.ws.rs.client.Client",
        "contentType": "method"
      }
    }
  }
